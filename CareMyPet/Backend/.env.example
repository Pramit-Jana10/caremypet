# App
PORT=5000
FLASK_DEBUG=false

# Database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGO_MAX_POOL_SIZE=50
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SERVER_SEL_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=10000

# Security
JWT_SECRET=replace-with-at-least-32-characters
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Admin bootstrap (optional)
ADMIN_EMAILS=admin@example.com,caremypetofficial@gmail.com
ADMIN_BOOTSTRAP_EMAIL=caremypetofficial@gmail.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-strong-password
ADMIN_BOOTSTRAP_NAME=CareMyPet Admin

# Mail (required for OTP/password reset)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_FROM_EMAIL=caremypetofficial@gmail.com
BREVO_REPLY_TO=caremypetofficial@gmail.com

# Frontend URL used in password reset links
FRONTEND_BASE_URL=https://your-frontend.vercel.app

# Optional features
GEMINI_API_KEY=
FIREBASE_SERVER_KEY=
